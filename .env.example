# ============================================================
# KODU PROJECT CONTROLS AI — Variables de entorno
# Copia este archivo como .env (NO subas .env a GitHub)
# ============================================================

# --- Base de datos (Supabase) ---
# Supabase → Settings → Database → Connection string → URI (modo "Transaction")
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres"
# Para migraciones de Prisma usa la conexión directa (puerto 5432):
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# --- Autenticación (NextAuth) ---
# Genera uno con: openssl rand -base64 32
NEXTAUTH_SECRET="REEMPLAZAR-con-secreto-aleatorio"
NEXTAUTH_URL="http://localhost:3000"   # en producción: https://tu-app.vercel.app

# --- IA (Claude / Anthropic) — reemplaza ABACUSAI_API_KEY ---
ANTHROPIC_API_KEY="sk-ant-REEMPLAZAR"

# --- Almacenamiento de archivos ---
# OPCIÓN A — AWS S3 propio (si mantienes tu bucket actual):
AWS_BUCKET_NAME=""
AWS_REGION="us-east-1"
AWS_FOLDER_PREFIX="kodu/"
# (las credenciales AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY las toma el SDK del entorno)

# OPCIÓN B — Supabase Storage (recomendado, un solo proveedor):
# Si migras a Supabase Storage, estas reemplazan a las de AWS.
# SUPABASE_URL="https://[ref].supabase.co"
# SUPABASE_SERVICE_ROLE_KEY=""

# --- PDF (generación propia con Puppeteer) ---
# En local, ruta a tu Chrome (ajusta según tu OS):
# macOS:   /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# Windows: C:\Program Files\Google\Chrome\Application\chrome.exe
# Linux:   /usr/bin/google-chrome
CHROME_PATH=""

# --- ELIMINADAS (eran de Abacus, ya no se usan) ---
# ABACUSAI_API_KEY   → reemplazada por ANTHROPIC_API_KEY
# WEB_APP_ID         → era de notificaciones Abacus
# NOTIF_ID_RFI_ANSWERED / NOTIF_ID_RFI_ASSIGNED → notificaciones Abacus (diferidas)
